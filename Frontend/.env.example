# ── API ─────────────────────────────────────────────────────────────────────
# Base URL for all httpClient / CsrfMiddleware requests (trailing slash required)
VITE_API_BASE_URL=http://localhost:3000/api/v1/

# ── Application identity ─────────────────────────────────────────────────────
# Full display name used in the navbar, sidebar, login page, and document titles
VITE_APP_NAME=CATHERINE
# Short name displayed when space is constrained (sidebar collapsed state, etc.)
VITE_APP_NAME_SHORT=CATHERINE

# ── Version & release stage ──────────────────────────────────────────────────
# Version string shown by the version badge (navbar/sidebar/version history).
# Leave unset to fall back to the version in package.json (injected at build time).
# A semver pre-release tag (e.g. 1.23.4-beta.2) auto-selects the stage below.
VITE_APP_VERSION=1.0.0
# Release stage shown next to the version. One of: dev | alpha | beta | rc | stable.
# Precedence: this var > pre-release tag on VITE_APP_VERSION > (prod ? stable : dev).
#   dev    → Developer Preview   alpha → Alpha          beta → Beta
#   rc     → Release Candidate   stable → Stable (production)
VITE_APP_STAGE=dev

# ── Layout ───────────────────────────────────────────────────────────────────
# Controls the default navigation chrome — "sidebar" or "top"
VITE_LAYOUT_MODE=sidebar

# ── Theme ────────────────────────────────────────────────────────────────────
# Default colour scheme on first load — "light", "dark", or "system"
VITE_THEME=system

# ── Environment flag ─────────────────────────────────────────────────────────
# Used by error pages to suppress signout calls in local development
# Set to "development" locally; leave unset (or set to "production") in prod
VITE_ENV=development

# ── Session / warning modal ──────────────────────────────────────────────────
# Total session lifetime in milliseconds (must match JWT_EXPIRES_IN on the backend)
# Default: 1 800 000 ms = 30 minutes
VITE_SESSION_TIMEOUT_MS=1800000
# How many seconds before expiry the warning modal appears and countdown starts
# Default: 30 s
VITE_SESSION_WARNING_SECS=30

# ── Navigation redirects ─────────────────────────────────────────────────────
# Landing page after a successful login for standard users.
# Defaults to /operations/consumption when unset.
VITE_DEFAULT_REDIRECT=/operations/consumption
# Landing page after login / password-change for ROBOT-role accounts.
# Defaults to the standard redirectPath when unset.
VITE_ROBOT_REDIRECT=/finance/subsidies
VITE_ROBOT_ROLE=ROBOT

# ── Observability ────────────────────────────────────────────────────────────
# Include process ID in client-side log output — "true" or "false"
VITE_PID_LOGGING=false

# ── Node / Vite internals ────────────────────────────────────────────────────
NODE_ENV=development
VITE_NODE_ENV=development
