{
    "name": "catherine-backend",
    "version": "1.0.0-dev.29",
    "description": "CATHERINE Template — Production-grade Express 5 + OracleDB backend with JWT auth, RBAC, audit logging, and observability.",
    "homepage": "https://github.com/Jm-Paunlagui/NodeExpress-Template#readme",
    "bugs": {
        "url": "https://github.com/Jm-Paunlagui/NodeExpress-Template/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Jm-Paunlagui/NodeExpress-Template.git"
    },
    "license": "ISC",
    "author": "Jm-Paunlagui",
    "type": "commonjs",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "seed:superadmin": "node scripts/seed-superadmin.js",
        "db:seed:template": "node scripts/seed-template.js",
        "simulate:excess": "node scripts/simulate-excess-deduction.js",
        "simulate:excess:verify": "node scripts/verify-simulate-excess-deduction.js",
        "simulate:excess:teardown": "node scripts/simulate-excess-deduction.js --teardown",
        "build": "pkg . --out-path dist --targets node18-win-x64 --no-bytecode --public --public-packages=*",
        "build:debug": "pkg . --out-path dist --targets node18-win-x64 --no-bytecode --public --public-packages=* --debug",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui",
        "test:unit": "vitest run test/server/unit",
        "test:integration": "vitest run test/server/integration",
        "test:security": "vitest run test/server/security",
        "test:performance": "vitest run test/server/performance",
        "test:reliability": "vitest run test/server/reliability",
        "test:chaos": "vitest run test/server/chaos",
        "test:metrics": "vitest run test/server/unit/middleware/metricsStore.test.js test/server/unit/middleware/metricsStore.memory.test.js test/server/unit/middleware/metricsRouteLabel.test.js test/server/unit/services/metricsService.test.js test/server/integration/metrics.test.js test/server/integration/metrics/metrics.test.js test/server/chaos/metrics-chaos.test.js",
        "test:audit:formula": "vitest run test/unit/services/settlementFormula.test.js"
    },
    "dependencies": {
        "archiver": "^8.0.0",
        "argon2": "^0.44.0",
        "axios": "^1.15.3",
        "bcryptjs": "^3.0.3",
        "blob-stream": "^0.1.3",
        "body-parser": "^2.2.2",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "csrf-csrf": "^4.0.3",
        "csv-parser": "^3.2.0",
        "dotenv": "^17.4.1",
        "exceljs": "^4.4.0",
        "express": "^5.2.1",
        "express-validator": "^7.3.2",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.10.1",
        "multer": "^2.1.1",
        "nanoid": "^5.1.7",
        "node-cache": "^5.1.2",
        "nodemailer": "^9.0.1",
        "oracledb": "^6.10.0",
        "pdfkit": "^0.18.0",
        "uuid": "^11.1.1"
    },
    "bin": {
        "catherine_backend": "./server.js"
    },
    "pkg": {
        "scripts": [
            "src/**/*.js",
            "server.js"
        ],
        "assets": [
            "src/**/*.js",
            "src/**/*.json",
            "src/**/*.png",
            "src/**/*.ttf",
            "node_modules/axios/dist/node/axios.cjs",
            "node_modules/axios/package.json",
            "node_modules/axios/lib/**/*",
            "node_modules/axios/dist/**/*",
            "node_modules/pdfkit/js/**/*",
            "node_modules/fontkit/dist/**/*",
            "node_modules/fontkit/src/**/*",
            "node_modules/oracledb/package.json",
            "node_modules/oracledb/lib/**/*",
            "node_modules/nanoid/index.js",
            "node_modules/nanoid/non-secure/index.js",
            "node_modules/nanoid/package.json"
        ],
        "targets": [
            "node18-win-x64"
        ],
        "outputPath": "dist"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^4.1.9",
        "supertest": "^7.2.2",
        "vitest": "^4.1.9"
    },
    "overrides": {
        "uuid": "^11.1.1"
    }
}
