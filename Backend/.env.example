# ─── Demo Mode ─────────────────────────────────────────────────────────────
# Set to 'true' to run the entire template with ZERO database setup.
# Authentication, audit logs, admin management, and changelog are served from
# in-memory fixtures. No Oracle pools are opened. Perfect for first-time setup.
DEMO_MODE=false

# ─── Server ────────────────────────────────────────────────────────────────
PORT=2108
HOST=0.0.0.0
NODE_ENV=production
USE_HTTPS=false
APP_NAME=CATHERINE
FRONTEND_BASE_URL=

# ─── Clustering ────────────────────────────────────────────────────────────
# ENABLE_CLUSTERING — fork NUM_WORKERS processes sharing the listen port.
# NUM_WORKERS       — 4–16 depending on server cores; defaults to core count.
#
# Per-worker resource math (read BEFORE raising NUM_WORKERS):
#   • Oracle pools are PER WORKER: total DB sessions ≈ NUM_WORKERS × MEAL_POOL_MAX
#     (+ userAccount pool). Keep that product within the DB PROCESSES/SESSIONS
#     limit — e.g. 8 workers × MEAL_POOL_MAX=10 ≈ 80 Meal sessions.
#     Scale MEAL_POOL_MAX DOWN as you scale workers UP.
#   • UV_THREADPOOL_SIZE is PER WORKER (memory: ~1 MB stack per thread).
#   • Rate limits are PER WORKER (in-memory store): the effective global limit
#     is ≈ NUM_WORKERS × RATE_LIMIT_MAX because client requests round-robin
#     across workers. Divide RATE_LIMIT_MAX accordingly when clustering.
#   • Cache invalidations are synced across workers automatically via the
#     primary process (ClusterCacheSync) — no configuration needed.
ENABLE_CLUSTERING=false
NUM_WORKERS=2

# ─── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here-change-in-production
JWT_EXPIRES_IN=30m                # Access token lifetime (s/m/h/d). Cookie maxAge matches this value.
JWT_REFRESH_EXPIRES_IN=7d

# ─── CSRF ──────────────────────────────────────────────────────────────────
CSRF_SECRET=your-csrf-secret-key-here-change-in-production

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:2106,http://localhost:5173,http://192.168.225.120:2106,http://192.168.225.120:5173

# CORS_ALLOW_BROAD_PATTERNS (optional, default: false)
#   In production (NODE_ENV=production), broad wildcard CORS patterns (*.vpn,
#   *.corp, *.internal, *.local, *.lan, and all RFC-1918 IP ranges) are disabled
#   by default (CWE-942 mitigation). Only CORS_ORIGINS (explicit list) is honoured.
#
#   Set to 'true' ONLY if you are deploying in an environment where origin
#   topology is trusted and an explicit allow-list is impractical.
#   DO NOT set to 'true' in internet-facing production deployments.
CORS_ALLOW_BROAD_PATTERNS=false

# ─── Cookies ───────────────────────────────────────────────────────────────
COOKIE_SECRET=              # ≥32 chars — signs HTTP-only cookies. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ─── Body Parsing ──────────────────────────────────────────────────────────
BODY_LIMIT=10mb

# ─── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
TRUST_PROXY=false

# ─── IP Filtering ──────────────────────────────────────────────────────────
ENABLE_IP_FILTER=false
ALLOWED_IPS=

# ─── Database (Oracle) ─────────────────────────────────────────────────────
# Skipped entirely when DEMO_MODE=true (no Oracle pool is opened).
DB_TYPE=oracle
DB_HOST=localhost
DB_PORT=1521
DB_APP_SERVICE_NAME=XEPDB1

APP_DB_USERNAME=
APP_DB_PASSWORD=

# ─── Oracle Pool Sizing ────────────────────────────────────────────────────
# Tune these based on concurrent user load. Oracle holds a server process per
# poolMin connection even when idle, so do not over-provision poolMin.
#   poolMin — connections kept alive at startup. Default: 2.
#   poolMax — hard ceiling; requests queue when pool is exhausted. Default: 10.
APP_POOL_MIN=2
APP_POOL_MAX=10

# ─── libuv Thread Pool (UV_THREADPOOL_SIZE) ────────────────────────────────
# node-oracledb (Thick mode) runs every DB call on a libuv worker thread; the
# Node.js default of 4 threads serialises concurrent Oracle work no matter how
# large the connection pool is. server.js defaults this to 48 (covers all pool
# maxima + fs/crypto headroom). IMPORTANT: the thread pool is created on first
# async I/O — before dotenv loads — so overriding this value only works as a
# REAL operating-system environment variable (system env / service config /
# `$env:UV_THREADPOOL_SIZE` before launch), NOT from this file.
# UV_THREADPOOL_SIZE=48

# ─── Database (Test / Dev) ─────────────────────────────────────────────────
# DB_TEST_HOST=192.168.231.62
# DB_TEST_PORT=1521
# DB_TEST_SID=MES
# UI_TEST_DB_USERNAME=OL_SCRAP
# UI_TEST_DB_PASSWORD=OL_SCRAP_2021

# ─── Oracle Instant Client ─────────────────────────────────────────────────
ORACLE_INSTANT_CLIENT=C:\\oracle\\instantclient_23_8
DB_TIMEZONE_OFFSET_MINUTES=480    # DB server UTC offset in minutes (480 = UTC+8 Philippines). Required for ROW_HASH verification in TamperDetectionService.

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENABLE_CONSOLE_LOGS=true
LOG_EXCLUDE_HEALTH=true
LOG_EXCLUDE_URLS=
LOG_MAX_SAFESTR_LENGTH=           # Defaults to Infinity (no truncation). Set a number only if needed.
LOG_CALLSITE=true                 # Capture function/file/line in logs

# ─── Password Hashing ──────────────────────────────────────────────────────
# Accepted: plain | bcrypt | argon2 | tripledes
#   plain  → No hashing. Development and unit testing ONLY. Never use in production.
#   bcrypt → Legacy mode. Use only when migrating existing bcrypt hashes.
#   argon2 → Recommended. OWASP #1 choice. Use for all new deployments.
#   tripledes → Legacy mode. Use only when migrating existing tripledes hashes.
#               requires a PASSWORD_KEY (encryption key) to be set. Not recommended for new applications.
PASSWORD_HASH_MODE=argon2
PASSWORD_KEY=

# ─── Admin Password Encryption Mode ────────────────────────────────────────
# Controls how T_ADMINS_DEV passwords are stored.
#
# When PASSWORD_HASH_MODE is already strong (bcrypt | argon2), this variable
# is NOT required — admin passwords follow PASSWORD_HASH_MODE automatically.
#
# The project recommendation is argon2 (OWASP #1).
PASSWORD_ENCRYPTION_MODE=argon2

# ─── Argon2 ────────────────────────────────────────────────────────────────
# Only applies when PASSWORD_HASH_MODE=argon2.
#
# ARGON2_PEPPER (required in argon2 mode)
#   A server-side secret mixed into every hash via HMAC-SHA256 before hashing.
#   Effect: a full DB leak alone is not enough to crack hashes without this value.
#   Rules:
#     - Minimum 32 characters (64-char hex string recommended)
#     - In production, inject via secrets manager — NOT from this file
#     - Rotating this invalidates ALL existing hashes. Treat it like a signing key.
#   Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ARGON2_PEPPER=replace_this_with_a_64_char_hex_string_generated_by_the_command_above

# ARGON2_MEMORY_COST (optional, default: 19456)
#   Memory used per hash in KiB. OWASP minimum: 19456 (~19 MiB).
#   Accepted range: 8192 – 4194304 (8 MiB – 4 GiB)
#     Low-resource server  → 19456    (OWASP minimum, safe baseline)
#     Standard API server  → 65536    (64 MiB, good balance)
#     High-security system → 262144   (256 MiB, very strong)
ARGON2_MEMORY_COST=19456

# ARGON2_TIME_COST (optional, default: 2)
#   Iteration count over memory. Increase if hashing feels too fast on your
#   hardware. Target: 200–500 ms per hash on your production server.
#   Accepted range: 1 – 999
ARGON2_TIME_COST=2

# ARGON2_PARALLELISM (optional, default: 1)
#   Parallel threads used during hashing. Should not exceed available CPU cores.
#   Accepted range: 1 – 64
ARGON2_PARALLELISM=1

# ARGON2_HASH_LENGTH (optional, default: 32)
#   Raw hash output length in bytes. 32 bytes (256 bits) is already overkill.
#   Accepted range: 16 – 128
ARGON2_HASH_LENGTH=32

# ARGON2_MAX_PASSWORD_BYTES (optional, default: 1024)
#   Hard cap on password input size. Prevents DoS via oversized payloads.
#   Unlike bcrypt, Argon2 has no silent truncation — but unbounded input is
#   still dangerous at the application layer.
#   Accepted range: 64 – 4096
ARGON2_MAX_PASSWORD_BYTES=1024

# ─── Data Integrity Signing ────────────────────────────────────────────────
# DATA_SIGNING_SECRET (required)
#   HMAC-SHA256 key used by CryptoVault.signData() / verifySignature() to
#   produce and verify tamper-evident SYSSIGNATURE values on DB rows.
#
#   Rules:
#     - Minimum 32 characters (64-char hex string recommended)
#     - Must be distinct from JWT_SECRET and ARGON2_PEPPER
#     - In production, inject via secrets manager — NOT from this file
#     - Rotating this invalidates ALL existing SYSSIGNATURE values in the DB
#   Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DATA_SIGNING_SECRET=replace_this_with_a_64_char_hex_string_generated_by_the_command_above

# ─── Changelog Encryption ─────────────────────────────────────────────────
# AES-256-GCM key used to encrypt the changelog JSON store at data/changelog.enc.
# 64-character hex string = 32 bytes.
# Falls back to DATA_SIGNING_SECRET when absent (not recommended for production).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CHANGELOG_ENCRYPTION_KEY=replace_this_with_a_64_char_hex_string_generated_by_the_command_above

# ─── Audit Log ─────────────────────────────────────────────────────────────
AUDIT_LOG_ENABLED=true             # false = disable DB persistence; file logs continue
AUDIT_LOG_EXCLUDE_HEALTH=true      # exclude /health from DB inserts
AUDIT_LOG_EXCLUDE_PATHS=/api/v1/audit-logs  # comma-separated path prefixes excluded from DB audit (prevents self-referencing flood when the Logs Management page is open)
AUDIT_LOG_RETENTION_DAYS=90        # planned — retention delete job (not in v1 scope)

# ─── Metrics / Observability ───────────────────────────────────────────────
# Comma-separated path prefixes excluded from per-route RED/latency metrics
# (MetricsMiddleware + ResponseTimeMiddleware). These are the observability
# dashboard's own polling traffic — recording it is an observer-effect distortion,
# and the long-lived /audit-logs/stream SSE would otherwise poison p95/p99/apdex
# with a session-length duration. Defaults to the two observability namespaces.
METRICS_EXCLUDE_PATHS=/api/v1/audit-logs,/api/v1/metrics

# ─── PKG ───────────────────────────────────────────────────────────────────
PFX_PASSPHRASE=                   # Passphrase for PFX certificate (HTTPS)

# ─── Login Lockout ─────────────────────────────────────────────────────────
# Per-user failed-login tracking (in-memory, 24h TTL).
# All vars are optional — defaults shown below.
LOGIN_MAX_ATTEMPTS=3            # Failed attempts before first lockout
LOGIN_LOCKOUT_MODE=incremental  # 'fixed' | 'incremental'
LOGIN_LOCKOUT_DURATION_MS=30000 # Base lockout duration in ms (30 s)
LOGIN_LOCKOUT_MULTIPLIER=2      # Incremental multiplier per cycle (incremental mode only)
LOGIN_MAX_LOCKOUT_CYCLES=3      # After this many cycles → HR-reset (permanent block, HTTP 423)
LOGIN_RETRY_DECREMENT=1         # Fewer attempts allowed each successive cycle

# ─── Admin Management ─────────────────────────────────────────────────────
# Default password assigned to every newly created admin, and restored when
# "reset password" is triggered via the Admin Management UI.
# Rules:
#   - Must be a non-trivial string — never leave blank in production
#   - Admins are forced to change this on first login (requiresPasswordChange=true)
#   - In production, inject via secrets manager — NOT hardcoded in this file
ADMIN_DEFAULT_PASSWORD=Change@Me123

# ─── Billing ──────────────────────────────────────────────────────────────
BILLING_HMAC_SECRET=         # ≥32 chars — HMAC-SHA256 key for Excel signature. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BILLING_SHEET_PASSWORD=      # Password for ExcelJS worksheet protection (arbitrary string; share out-of-band with recipients)

# ─── SMTP (billing email notifications) ───────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@meal.internal

# ─── Settlement Configuration ──────────────────────────────────────────────
# Controls admin re-settlement guardrails.

# Minimum minutes between re-settlement runs for the same cutoff period.
# Prevents admins from re-triggering before the previous batch is reflected.
# Default: 10 minutes.
SETTLEMENT_COOLDOWN_MINUTES=10

# Maximum number of re-settlement versions allowed per cutoff period.
# After this limit is reached, contact system administration to reset.
# Default: 5.
SETTLEMENT_MAX_VERSIONS=5

# ─── Docker ───────────────────────────────────────────────────────────────
DOCKER_CONTAINER=false